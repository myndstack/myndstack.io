# Canonical origin — feeds metadataBase, canonical URLs, robots.txt and sitemap.xml.
NEXT_PUBLIC_SITE_URL=https://myndstack.io

# Resend (https://resend.com). Without a key, form submissions are logged to the
# server console in development and rejected outright in production.
RESEND_API_KEY=
# Where enquiries, newsletter signups and applications land.
CONTACT_TO_EMAIL=hello@myndstack.io
# Must be an address on a domain verified in Resend.
CONTACT_FROM_EMAIL=Myndstack <hello@myndstack.io>

# How many proxies in front of this app are trusted to append to
# X-Forwarded-For. 1 is right for Vercel and most managed hosts. Set higher only
# if you genuinely run additional trusted hops — every extra hop you claim is one
# more attacker-controlled entry the rate limiter will believe.
TRUSTED_PROXY_HOPS=1

# Optional: set to your Plausible site domain to enable analytics. Leave blank to
# ship no analytics script at all.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
