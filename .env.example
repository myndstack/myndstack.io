# Canonical origin — feeds metadataBase, canonical URLs, robots.txt and sitemap.xml.
NEXT_PUBLIC_SITE_URL=https://myndstack.io

# Resend (https://resend.com). Without a key, form submissions are logged to the
# server console in development and rejected outright in production.
RESEND_API_KEY=
# Where enquiries, newsletter signups and applications land. Falls back to
# hello@myndstack.io, which is the address in SITE — so this one is safe to omit.
CONTACT_TO_EMAIL=hello@myndstack.io
# Must be an address on a domain verified in Resend, and REQUIRED in production.
# Unlike the recipient, the fallback here is wrong rather than merely absent: it
# is Resend's shared onboarding@resend.dev, which only delivers to your own Resend
# account address. A production deployment that leaves this unset — or that sets
# it to anything on resend.dev — is refused at boot. See lib/mail-config.ts.
CONTACT_FROM_EMAIL=Myndstack <hello@myndstack.io>

# How many proxies in front of this app are trusted to append to
# X-Forwarded-For. 1 is right for Vercel and most managed hosts. Set higher only
# if you genuinely run additional trusted hops — every extra hop you claim is one
# more attacker-controlled entry the rate limiter will believe.
TRUSTED_PROXY_HOPS=1

# How mail leaves the process: "resend" or "console", and nothing else — an
# unrecognised value is an error rather than a silent fall back to inference.
# Defaults to resend when a key is present, console when not. CI and the e2e
# suite force "console" so form submission can be tested against a production
# build without a live provider.
#
# Do NOT set this to "console" on a real deployment to quiet a misconfiguration.
# Every form would return success, show the visitor "Message received", and write
# the lead to stdout. That loses leads far more quietly than the error does; the
# server warns about it at every boot and /api/health reports deliverable:false.
MAIL_TRANSPORT=

# Optional: Resend audience id. Newsletter signups are added to this list on top
# of the notification email. Unset = email only.
RESEND_AUDIENCE_ID=

# Optional: HubSpot private-app token. Contact submissions upsert a contact
# record (standard properties only). Unset = no CRM write.
# NOTE: failures here are logged and swallowed by design — the email still
# delivers — so a bad token degrades silently. Check logs after configuring.
HUBSPOT_ACCESS_TOKEN=

# Optional: Cal.com link (e.g. "myndstack/intro"). Renders an inline booking
# embed under the contact details. Unset = no embed and no third-party script.
NEXT_PUBLIC_CAL_LINK=

# Optional: set to your Plausible site domain to enable analytics. Leave blank to
# ship no analytics script at all.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---------------------------------------------------------------------------
# Sanity (content management)
#
# Marketing content — roles, case studies, testimonials, team, FAQ, pricing,
# homepage copy — lives in Sanity so it can be edited without a code change.
# The Studio is standalone (`npm run studio:dev` / `studio:deploy`), NOT embedded
# in this app; editors use its *.sanity.studio URL. NAV_LINKS, the legal docs and
# the pinned stack-story layers stay in code on purpose; they are structure the
# page is written against, not editorial copy. See README.
# ---------------------------------------------------------------------------

# Public — both ship to the browser, which the Studio and image URLs require.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only read token. OPTIONAL — the public dataset reads without it and
# content pages render dynamically (always fresh). Set a Viewer token only if you
# later want drafts or higher rate limits. Create it at sanity.io/manage → API.
SANITY_API_READ_TOKEN=

# Server-only write token. Used ONLY by scripts/seed-sanity.ts to import the
# initial content; never read at runtime. Create an Editor token, seed once,
# then revoke it. Leave blank in normal operation.
SANITY_API_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# After deploying, check the configuration above actually took:
#
#   curl https://myndstack.io/api/health
#
#   {"ok":true,"deliverable":true}    mail reaches a person
#   {"ok":true,"deliverable":false}   forms succeed, nothing is delivered
#   {"ok":false,...} (HTTP 503)       forms will fail; the server log says why
# ---------------------------------------------------------------------------
