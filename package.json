    "studio:build": "sanity build",
    "studio:deploy": "sanity deploy"
  },
  "dependencies": {
    "@sanity/client": "^7.24.0",
    "@sanity/image-url": "^1.2.0",
    "@sanity/vision": "^5.31.1",
    "@sanity/webhook": "^4.0.4",
    "next": "^15.5.4",
    "next-sanity": "^11.6.13",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "resend": "^6.18.0",
    "sanity": "^5.31.1",
    "server-only": "^0.0.1",
    "styled-components": "^6.4.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^22.18.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.4",
    "tailwindcss": "^4.1.13",
